# ──────────────────────────────────────────────────────────────────────────────
# Environment variables
# Copy this file to .env and fill in ONLY the keys you want.
# The pipeline works with ZERO keys — everything below is optional.
# ──────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════════
#  FREE / PUBLIC SOURCES — No keys needed, already working out of the box:
#    Reddit (public JSON), News RSS, Twitter/X (Nitter), YouTube (Invidious),
#    Stock prices (yfinance), Sentiment (VADER), Agent Swarm (Bing News RSS)
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
#  OPTIONAL: AI LLM Key — unlocks smarter analysis (costs a few cents per run)
#
#  Pick ONE provider and set the corresponding key.
#  To switch providers, just change LLM_PROVIDER and LLM_API_KEY.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Generic LLM config (recommended) ──────────────────────────────────────────
# LLM_PROVIDER=kimi          # Options: kimi | openai | gemini | claude
# LLM_API_KEY=your_key_here

# Optional overrides:
# LLM_MODEL=                 # Leave empty for provider default
# LLM_BASE_URL=              # Leave empty for provider default

# ── Provider-specific keys (fallback if LLM_API_KEY not set) ──────────────────
# KIMI_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
# GEMINI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here

# ═══════════════════════════════════════════════════════════════════════════════
#  OPTIONAL: Higher rate limits / direct APIs — replace public mirrors
# ═══════════════════════════════════════════════════════════════════════════════

# ── Reddit OAuth2 — fewer 403 blocks than public API ──────────────────────────
# Create an app at https://www.reddit.com/prefs/apps (select "script")
# REDDIT_CLIENT_ID=your_client_id
# REDDIT_CLIENT_SECRET=your_client_secret

# ── NewsAPI — additional news sources beyond RSS ──────────────────────────────
# Get your key at: https://newsapi.org/ (free tier available)
# NEWSAPI_KEY=your_key_here

# ── X/Twitter Bearer Token — replaces Nitter RSS mirrors ──────────────────────
# Apply at https://developer.twitter.com/
# X_BEARER_TOKEN=your_bearer_token

# ═══════════════════════════════════════════════════════════════════════════════
#  STUB / NOT YET ACTIVE — These collectors return empty until implemented
# ═══════════════════════════════════════════════════════════════════════════════

# TIKTOK_API_KEY=your_key_here

# ── Meta (Facebook / Instagram) Graph API ─────────────────────────────────────
# META_APP_ID=your_app_id
# META_APP_SECRET=your_app_secret
